# Coach: Anthropic API key is stored as a Firebase Function secret (not in the app).
# firebase functions:secrets:set ANTHROPIC_API_KEY

# Native Sign-In (Capacitor only — leave blank for pure web/PWA build)
# Created in Google Cloud Console → Credentials → OAuth 2.0 Client IDs
# Web client ID is the one Firebase Auth uses (same value across iOSServerClientId + webClientId).
VITE_GOOGLE_WEB_CLIENT_ID=
# iOS-specific OAuth client (type: iOS) — its REVERSED_CLIENT_ID goes into Info.plist.
VITE_GOOGLE_IOS_CLIENT_ID=
# Apple: required ONLY for Android Sign-In (Service ID created in Apple Developer portal). iOS uses the app bundle ID.
VITE_APPLE_SERVICE_ID=
# Apple: redirect URL configured for the Service ID (Android only). Leave blank for iOS-only setups.
VITE_APPLE_REDIRECT_URL=
