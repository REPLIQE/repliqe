<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <!-- Status + navigation bars match splash_background so the system bars never flash white
             during the WebView load gap. windowLightStatusBar=false keeps the icons (clock/battery)
             rendered as light glyphs on the dark backdrop. -->
        <item name="android:statusBarColor">@color/splash_background</item>
        <item name="android:navigationBarColor">@color/splash_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <!--
      Launch theme — uses the AndroidX SplashScreen API (Theme.SplashScreen).
      On Android 12+ the system renders the splash itself; on older versions the
      core-splashscreen library back-ports the same behavior. The legacy
      `android:background` attribute is ignored by this API, so we set:
        - windowSplashScreenBackground       : the solid backdrop color (dark)
        - windowSplashScreenAnimatedIcon     : intentionally a transparent 1x1 vector
                                               so the system splash shows ONLY the dark
                                               background. If we used ic_launcher_foreground
                                               the icon would render at a different
                                               on-screen position than the brand splash icon
                                               and produce a visible "bump" during handoff.
        - postSplashScreenTheme              : theme to switch to once the
                                               Activity finishes inflating
      android:statusBarColor / navigationBarColor are also set explicitly here so the
      bars are dark from the very first frame the OS draws (the system splash respects
      these on API 23+). Brand composition (icon + wordmark + tagline) is then rendered
      as inline SVG by index.html as soon as the WebView starts parsing.
    -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_blank_icon</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
        <item name="android:statusBarColor">@color/splash_background</item>
        <item name="android:navigationBarColor">@color/splash_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
